# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env.local
.sentryclirc
undefined:/Users/

# Windows download metadata (can appear in WSL)
*:Zone.Identifier

# Ralph runtime verifier outputs (local-only)
brain/workers/ralph/.verify/run_id.txt
brain/workers/ralph/.verify/latest.txt
