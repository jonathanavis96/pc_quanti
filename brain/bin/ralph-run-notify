#!/usr/bin/env bash
set -euo pipefail

# ralph-run-notify - Ralph-oriented wrapper around Ralph loop with best-effort notifications.
#
# Intended usage: wrap longer Ralph loop runs so you don't need to babysit the terminal.
#
# Usage:
#   ralph-run-notify [OPTIONS] -- [LOOP_ARGS...]
#
# Options:
#   --dry-run                Print what would be executed without running loop
#   --log FILE               Log file to scan for HUMAN_REQUIRED markers (optional)
#   --min-seconds N          Only notify on SUCCESS if runtime >= N seconds (default: 120)
#   --always-notify-success  Always notify on SUCCESS (ignores --min-seconds)
#   --help                   Show this help message
#
# Behavior:
#   - Runs: bash workers/ralph/loop.sh [LOOP_ARGS...]
#   - On exit 0 (SUCCESS): notifies ONLY if runtime >= threshold (or --always-notify-success)
#   - On non-zero with HUMAN_REQUIRED marker: always notifies (sound + TTS)
#   - On non-zero (FAIL): always notifies (sound + TTS)
#   - Preserves original exit code
#   - Notifications are best-effort: never cause wrapper failure
#   - Titles are project-prefixed: "Ralph <project> complete|needs you|error"

usage() {
  sed -n '3,30p' "$0" | sed 's/^# //' | sed 's/^#//'
  exit 0
}

DRY_RUN=false
LOG_FILE=""
LOOP_ARGS=()

MIN_SECONDS_DEFAULT=120
MIN_SECONDS="${RALPH_NOTIFY_MIN_SECONDS:-$MIN_SECONDS_DEFAULT}"
ALWAYS_NOTIFY_SUCCESS=false

# Parse wrapper options before --
while [[ $# -gt 0 ]]; do
  case "$1" in
    --help)
      usage
      ;;
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    --log)
      if [[ $# -lt 2 ]] || [[ "${2:-}" == --* ]]; then
        echo "Error: --log requires a file path" >&2
        exit 1
      fi
      LOG_FILE="$2"
      shift 2
      ;;
    --min-seconds)
      if [[ $# -lt 2 ]] || [[ "${2:-}" == --* ]]; then
        echo "Error: --min-seconds requires an integer number of seconds" >&2
        exit 1
      fi
      MIN_SECONDS="$2"
      shift 2
      ;;
    --always-notify-success)
      ALWAYS_NOTIFY_SUCCESS=true
      shift
      ;;
    --)
      shift
      LOOP_ARGS=("$@")
      break
      ;;
    *)
      echo "Error: Unknown option '$1'" >&2
      echo "Use '--' to separate wrapper options from loop arguments" >&2
      echo "Example: ralph-run-notify --min-seconds 120 -- --iterations 10" >&2
      exit 1
      ;;
  esac
done

if ! [[ "$MIN_SECONDS" =~ ^[0-9]+$ ]]; then
  echo "Error: --min-seconds must be an integer number of seconds" >&2
  exit 1
fi

# Get absolute paths to bin/notify and tools/detect_human_required.py
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
NOTIFY_BIN="$SCRIPT_DIR/notify"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
DETECT_HUMAN="$REPO_ROOT/tools/detect_human_required.py"

if [[ ! -x "$NOTIFY_BIN" ]]; then
  echo "Error: bin/notify not found or not executable: $NOTIFY_BIN" >&2
  exit 1
fi

if [[ ! -f "$DETECT_HUMAN" ]]; then
  echo "Error: tools/detect_human_required.py not found: $DETECT_HUMAN" >&2
  exit 1
fi

# Determine project label for notification titles
# Priority: BRAIN_PROJECT_LABEL > PROJECT_LABEL > git repo basename > pwd basename
PROJECT_LABEL="${BRAIN_PROJECT_LABEL:-${PROJECT_LABEL:-}}"
if [[ -z "$PROJECT_LABEL" ]]; then
  if git rev-parse --show-toplevel >/dev/null 2>&1; then
    PROJECT_LABEL="$(basename "$(git rev-parse --show-toplevel)")"
  else
    PROJECT_LABEL="$(basename "$PWD")"
  fi
fi

# Dry-run mode
if [[ "$DRY_RUN" == "true" ]]; then
  echo "=== DRY RUN ==="
  echo "Would execute: bash ${REPO_ROOT}/workers/ralph/loop.sh ${LOOP_ARGS[*]}"
  echo ""
  echo "Project label: $PROJECT_LABEL"
  echo ""
  echo "Success notification policy:"
  echo "  min-seconds=$MIN_SECONDS (env: RALPH_NOTIFY_MIN_SECONDS), always-notify-success=$ALWAYS_NOTIFY_SUCCESS"
  echo ""
  echo "On SUCCESS (exit 0 + duration >= threshold):"
  echo "  $NOTIFY_BIN --level info --title '$PROJECT_LABEL complete' --message 'Ralph complete' --tts"
  echo ""
  echo "On HUMAN_REQUIRED (exit != 0 + marker detected):"
  echo "  $NOTIFY_BIN --level warn --title '$PROJECT_LABEL needs you' --message 'Ralph human required' --sound --tts"
  echo ""
  echo "On FAIL (exit != 0):"
  echo "  $NOTIFY_BIN --level error --title '$PROJECT_LABEL error' --message 'Ralph error' --sound --tts"

  if [[ -n "$LOG_FILE" ]]; then
    echo ""
    echo "Log file: $LOG_FILE"
    if [[ -f "$LOG_FILE" ]]; then
      echo "Testing HUMAN_REQUIRED detection..."
      if python3 "$DETECT_HUMAN" "$LOG_FILE"; then
        echo "✓ HUMAN_REQUIRED marker detected in log"
      else
        echo "✗ No HUMAN_REQUIRED marker in log"
      fi
    else
      echo "Warning: Log file not found (would skip detection)"
    fi
  fi

  exit 0
fi

start_ts=$(date +%s)

# Execute Ralph loop with provided arguments
set +e
bash "${REPO_ROOT}/workers/ralph/loop.sh" "${LOOP_ARGS[@]}"
EXIT_CODE=$?
set -e

end_ts=$(date +%s)
duration=$((end_ts - start_ts))

should_notify_success=false
if [[ "$ALWAYS_NOTIFY_SUCCESS" == "true" ]]; then
  should_notify_success=true
elif [[ $duration -ge $MIN_SECONDS ]]; then
  should_notify_success=true
fi

send_notify() {
  # Best-effort: never fail the caller
  "$NOTIFY_BIN" "$@" >/dev/null 2>&1 || true
}

# Send notification based on exit code and HUMAN_REQUIRED detection
if [[ $EXIT_CODE -eq 0 ]]; then
  if [[ "$should_notify_success" == "true" ]]; then
    send_notify --level info --title "$PROJECT_LABEL complete" --message "Ralph complete" --tts
  fi
  echo "Ralph: SUCCESS (duration=${duration}s)"
else
  # Check for HUMAN_REQUIRED markers
  HUMAN_REQUIRED=false
  if [[ -n "$LOG_FILE" ]] && [[ -f "$LOG_FILE" ]]; then
    if python3 "$DETECT_HUMAN" "$LOG_FILE"; then
      HUMAN_REQUIRED=true
    fi
  fi

  if [[ "$HUMAN_REQUIRED" == "true" ]]; then
    send_notify --level warn --title "$PROJECT_LABEL needs you" --message "Ralph human required" --sound --tts
    echo "Ralph: HUMAN_REQUIRED (exit $EXIT_CODE, duration=${duration}s)"
  else
    send_notify --level error --title "$PROJECT_LABEL error" --message "Ralph error" --sound --tts
    echo "Ralph: FAIL (exit $EXIT_CODE, duration=${duration}s)"
  fi
fi

# Preserve original exit code
exit $EXIT_CODE
